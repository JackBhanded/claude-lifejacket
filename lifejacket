#!/usr/bin/env bash
# Run Claude Lifejacket from this folder on macOS/Linux without PATH fuss.
# Adds the bundled src/ to PYTHONPATH so it works even without a pip install.
DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PYTHONPATH="$DIR/src:$PYTHONPATH"
exec python3 -m claude_lifejacket "$@"
